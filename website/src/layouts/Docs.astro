---
import Base from "./Base.astro";
import Sidebar from "../components/Sidebar.astro";
import WidgetSidebar from "../components/WidgetSidebar.astro";
import PageNav from "../components/PageNav.astro";
import Toc from "../components/Toc.astro";
import { CATEGORY_LABEL, type Doc } from "../nav";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  doc: Doc;
  prev?: Doc;
  next?: Doc;
  headings?: Heading[];
}
const { doc, prev, next, headings = [] } = Astro.props;
const { title, description, category } = doc.data;
// The widgets index belongs to the Widgets area, so it gets that sidebar.
const isWidgetsIndex = doc.id === "reference/widgets";
---

<Base title={title} description={description}>
  <div class="docs">
    {isWidgetsIndex ? <WidgetSidebar /> : <Sidebar currentId={doc.id} />}
    <article class="docs__main">
      <p class="docs__kicker">{CATEGORY_LABEL[category]}</p>
      <h1 class="docs__title">{title}</h1>
      <p class="docs__lead">{description}</p>
      <div class="prose">
        <slot />
      </div>
      <PageNav prev={prev} next={next} />
    </article>
    <Toc headings={headings} />
  </div>
</Base>
