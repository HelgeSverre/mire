---
import { GROUPS } from "../widgets-data";

// Inline the real-output SVG screenshots (generated by the Mire.Shots tool) so the
// page's JetBrains Mono applies to their text. Raw import keeps them as markup.
const shots = import.meta.glob("../generated/shots/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
}) as Record<string, string>;

const shotFor = (id?: string) =>
  id ? shots[`../generated/shots/${id}.svg`] : undefined;
---

{
  GROUPS.map((group) => (
    <section class="wg-group">
      <h2 id={group.name.toLowerCase().replace(/[^a-z]+/g, "-")}>{group.name}</h2>
      <p class="wg-blurb">{group.blurb}</p>
      {group.widgets.map((w) => {
        const svg = shotFor(w.shot);
        return (
          <div class="widget" id={w.id}>
            <h3>{w.title}</h3>
            <p class="widget__summary">{w.summary}</p>
            {svg && <figure class="widget__shot" set:html={svg} />}
            <pre class="sig"><code>{w.signature}</code></pre>
            <table class="param-table">
              <thead>
                <tr>
                  <th>parameter</th>
                  <th>type</th>
                  <th>what it is</th>
                </tr>
              </thead>
              <tbody>
                {w.params.map((p) => (
                  <tr>
                    <td><code>{p.name}</code></td>
                    <td><code>{p.type}</code></td>
                    <td>{p.desc}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        );
      })}
    </section>
  ))
}
