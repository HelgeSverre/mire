---
import { GROUPS } from "../widgets-data";

interface Props {
  // The current widget's id, or undefined on the widgets index.
  currentId?: string;
}
const { currentId } = Astro.props;
const onIndex = !currentId;
---

<nav class="sidebar" aria-label="Widgets" data-pagefind-ignore>
  <ul class="sidebar__flat">
    <li>
      <a href="/docs/reference/widgets/" aria-current={onIndex ? "page" : undefined}>All widgets</a>
    </li>
  </ul>
  {
    GROUPS.map((group) => (
      <details class="sidebar__group" open>
        <summary class="sidebar__title">{group.name}</summary>
        <ul>
          {group.widgets.map((w) => (
            <li>
              <a href={`/docs/reference/widgets/${w.id}/`} aria-current={w.id === currentId ? "page" : undefined}>
                {w.title}
              </a>
            </li>
          ))}
        </ul>
      </details>
    ))
  }
  <ul class="sidebar__flat sidebar__flat--foot">
    <li>
      <a href="/docs/">← All docs</a>
    </li>
  </ul>
</nav>
